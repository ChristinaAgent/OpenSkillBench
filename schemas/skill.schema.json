{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openskillbench.dev/schemas/skill.schema.json",
  "title": "OpenSkillBench Skill Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "supported_agents",
    "trigger_conditions",
    "required_tools",
    "safety_notes",
    "examples"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "supported_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safety_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "task",
          "expected_behavior"
        ],
        "additionalProperties": false,
        "properties": {
          "task": {
            "type": "string"
          },
          "expected_behavior": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "benchmark_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
